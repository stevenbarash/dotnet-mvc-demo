{
  // ==========================================================================
  // appsettings.json — Descope configuration
  // ==========================================================================
  // Only TWO settings are required to integrate Descope:
  //   1. Descope:ProjectId      — Your project ID from the Descope Console
  //   2. Authentication:ValidationMode — "JwtBearer" or "DescopeSdk"
  //
  // The ManagementKey is optional and only needed if you want to use the
  // Descope Management API (e.g., to fetch tenant SSO apps for the dashboard).
  // ==========================================================================
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Descope": {
    // Find your Project ID in the Descope Console → Project Settings
    "ProjectId": "YOUR_DESCOPE_PROJECT_ID",

    // Management Key — only needed for admin operations like fetching tenant
    // apps. Generate one in Descope Console → Company → Management Keys.
    "ManagementKey": "YOUR_DESCOPE_MANAGEMENT_KEY"
  },
  "Authentication": {
    // "JwtBearer"  — validates tokens using standard ASP.NET Core JWT middleware
    // "DescopeSdk" — validates tokens using the Descope SDK directly
    "ValidationMode": "JwtBearer"
  }
}
